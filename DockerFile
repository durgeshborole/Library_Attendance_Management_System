# ─────────────────────────────────────────────
#  Python-only Docker image for the
#  Flask Face Recognition microservice
#  Deploy this on Render (or Railway / Fly.io)
# ─────────────────────────────────────────────

FROM python:3.9-slim

# System dependencies required by OpenCV and InsightFace
RUN apt-get update && apt-get install -y \
    build-essential \
    cmake \
    libgl1-mesa-glx \
    libglib2.0-0 \
    libgomp1 \
    && rm -rf /var/lib/apt/lists/*

# Set working directory
WORKDIR /app

# Install Python dependencies first (cached layer)
COPY requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt

# Copy only the files needed for face recognition
COPY Face_recognition_model.py ./
COPY simple_facerec.py ./
COPY migrate_encodings.py ./
COPY face_cache.pkl ./
COPY faces/ ./faces/

# Render assigns a PORT env variable — Flask must bind to it
ENV PORT=5001

# Expose the port
EXPOSE 5001

# Start the Flask server
CMD ["python", "Face_recognition_model.py"]