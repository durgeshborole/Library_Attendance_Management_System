# Use Python base (needed for face_recognition dependencies)
FROM python:3.9-slim

# Install system dependencies for OpenCV and Node.js
RUN apt-get update && apt-get install -y \
    curl \
    build-essential \
    cmake \
    libgl1-mesa-glx \
    libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/*

# Install Node.js (Version 18)
RUN curl -fsSL https://deb.nodesource.com/setup_18.x | bash - \
    && apt-get install -y nodejs

# Create App Directory
WORKDIR /app

# Install Node dependencies
COPY package*.json ./
RUN npm install

# Install Python dependencies
COPY requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt

# Copy all project files
COPY . .

# Set environment variables (Render will also set these)
ENV PORT=5000

# Start both services: Node.js in foreground, Python in background
# 'sh -c' allows running multiple commands
CMD ["sh", "-c", "python face_recognition.py & npm start"]